# Copy this file to .env and fill in real values. Never commit .env.

# Neon Postgres. Get this from your Neon project dashboard -> Connection Details.
# Use the POOLED connection string (it contains "-pooler") for the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/fatora?sslmode=require"

# The DIRECT (non-pooled) connection string — same project, without "-pooler".
# Prisma Migrate needs this; migrations fail over a pooled connection.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/fatora?sslmode=require"

# Auth.js. Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-me-with-a-random-32-byte-string"

# Base URL of the app.
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
